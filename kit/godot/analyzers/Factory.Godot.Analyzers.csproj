<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Roslyn analyzers for the Godot C# profile. Reference from the game .csproj as an
    analyzer (see kit/godot/README.md); the diagnostics then run inside `dotnet build`,
    so `just godot-lint` needs no separate grep step.
  -->
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.8.0" PrivateAssets="all" />
  </ItemGroup>

</Project>
